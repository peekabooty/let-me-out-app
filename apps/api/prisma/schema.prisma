generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id                          String                      @id @db.Uuid
  email                       String                      @unique @db.VarChar(255)
  name                        String                      @db.VarChar(255)
  password_hash               String?                     @db.VarChar(255)
  role                        String                      @db.VarChar(50)
  is_active                   Boolean                     @default(false)
  activation_token_hash       String?                     @db.VarChar(64)
  activation_token_expires_at DateTime?                   @db.Timestamptz(6)
  created_at                  DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime                    @db.Timestamptz(6)
  absences            absence[]
  assigned_validations absence_validator[]        @relation("validator_assignments")
  validations         absence_validation_history[] @relation("validator_absence_history")
  status_changes      absence_status_history[]     @relation("status_changed_by")
  observations        observation[]
  notifications       notification[]
  team_memberships    team_member[]
}

model absence_type {
  id                  String   @id @db.Uuid
  name                String   @db.VarChar(255)
  unit                String   @db.VarChar(10)
  max_per_year        Decimal  @db.Decimal(6, 2)
  min_duration        Decimal  @db.Decimal(6, 2)
  max_duration        Decimal  @db.Decimal(6, 2)
  requires_validation Boolean  @default(false)
  allow_past_dates    Boolean  @default(false)
  min_days_in_advance Int?
  is_active           Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @db.Timestamptz(6)
  absences            absence[]
}

model absence {
  id              String                      @id @db.Uuid
  user_id         String                      @db.Uuid
  absence_type_id String                      @db.Uuid
  start_at        DateTime                    @db.Timestamptz(6)
  end_at          DateTime                    @db.Timestamptz(6)
  duration        Decimal                     @db.Decimal(6, 2)
  status          String?                     @db.VarChar(50)
  created_at      DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at      DateTime                    @db.Timestamptz(6)
  user            user                        @relation(fields: [user_id], references: [id])
  absence_type    absence_type                @relation(fields: [absence_type_id], references: [id])
  assigned_validators absence_validator[]
  validation_history absence_validation_history[]
  status_history     absence_status_history[]
  observations       observation[]
  notifications      notification[]

  @@index([user_id])
  @@index([absence_type_id])
}

model absence_validation_history {
  id            String   @id @db.Uuid
  absence_id    String   @db.Uuid
  validator_id  String   @db.Uuid
  decision      String   @db.VarChar(20)
  decided_at    DateTime @default(now()) @db.Timestamptz(6)
  absence       absence  @relation(fields: [absence_id], references: [id])
  validator     user     @relation("validator_absence_history", fields: [validator_id], references: [id])

  @@index([absence_id])
  @@index([validator_id])
}

model absence_status_history {
  id          String   @id @db.Uuid
  absence_id  String   @db.Uuid
  from_status String?  @db.VarChar(50)
  to_status   String   @db.VarChar(50)
  changed_by  String   @db.Uuid
  changed_at  DateTime @default(now()) @db.Timestamptz(6)
  absence     absence  @relation(fields: [absence_id], references: [id])
  changer     user     @relation("status_changed_by", fields: [changed_by], references: [id])

  @@index([absence_id])
  @@index([changed_by])
}

model observation {
  id         String   @id @db.Uuid
  absence_id String   @db.Uuid
  user_id    String   @db.Uuid
  content    String   @db.Text
  created_at DateTime @default(now()) @db.Timestamptz(6)
  absence    absence  @relation(fields: [absence_id], references: [id])
  user       user     @relation(fields: [user_id], references: [id])
  attachments observation_attachment[]

  @@index([absence_id])
  @@index([user_id])
}

model notification {
  id         String   @id @db.Uuid
  user_id    String   @db.Uuid
  absence_id String   @db.Uuid
  type       String   @db.VarChar(100)
  message    String   @db.Text
  read       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user       user     @relation(fields: [user_id], references: [id])
  absence    absence  @relation(fields: [absence_id], references: [id])

  @@index([user_id])
  @@index([absence_id])
}

model team {
  id         String   @id @db.Uuid
  name       String   @db.VarChar(255)
  color      String   @db.VarChar(7)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @db.Timestamptz(6)
  members    team_member[]
}

model team_member {
  team_id   String   @db.Uuid
  user_id   String   @db.Uuid
  joined_at DateTime @default(now()) @db.Timestamptz(6)
  team      team     @relation(fields: [team_id], references: [id])
  user      user     @relation(fields: [user_id], references: [id])

  @@id([team_id, user_id])
  @@index([user_id])
}

model observation_attachment {
  id              String   @id @db.Uuid
  observation_id  String   @db.Uuid
  filename        String   @db.VarChar(255)
  stored_filename String   @db.VarChar(255)
  mime_type       String   @db.VarChar(100)
  size_bytes      Int
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  observation     observation @relation(fields: [observation_id], references: [id])

  @@index([observation_id])
}

model absence_validator {
  absence_id    String   @db.Uuid
  validator_id  String   @db.Uuid
  assigned_at   DateTime @default(now()) @db.Timestamptz(6)
  absence       absence  @relation(fields: [absence_id], references: [id])
  validator     user     @relation("validator_assignments", fields: [validator_id], references: [id])

  @@id([absence_id, validator_id])
  @@index([validator_id])
}
