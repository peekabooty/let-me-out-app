# ──────────────────────────────────────────────
# Dependencias
# ──────────────────────────────────────────────
**/node_modules/

# ──────────────────────────────────────────────
# pnpm
# ──────────────────────────────────────────────
.pnpm-store/
.pnpm-debug.log

# ──────────────────────────────────────────────
# Builds y artefactos compilados
# ──────────────────────────────────────────────
dist/
build/
*.js.map
*.d.ts.map

# ──────────────────────────────────────────────
# Turborepo
# ──────────────────────────────────────────────
.turbo/

# ──────────────────────────────────────────────
# Prisma
# ──────────────────────────────────────────────
# Los ficheros .db y .sqlite pueden generarse en tests locales
*.db
*.sqlite

# ──────────────────────────────────────────────
# Variables de entorno
# ──────────────────────────────────────────────
# .env.example sí se versiona; el resto no
.env
.env.local
.env.*.local

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────────
# Tests y cobertura
# ──────────────────────────────────────────────
coverage/
.nyc_output/

# ──────────────────────────────────────────────
# Ficheros adjuntos (uploads del servidor)
# ──────────────────────────────────────────────
uploads/

# ──────────────────────────────────────────────
# Editores e IDEs
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ──────────────────────────────────────────────
# Sistema operativo
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
