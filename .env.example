# Backend
DATABASE_URL=postgresql://user:password@host:5432/absence_management?schema=public
APP_PORT=3000

# Auth
JWT_SECRET=replace_with_random_32_chars_minimum
JWT_REFRESH_SECRET=replace_with_random_32_chars_minimum
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_user
SMTP_PASS=your_password
SMTP_FROM="Sistema de Ausencias" <no-reply@empresa.com>

# CORS
CORS_ORIGIN=http://localhost:5173
COOKIE_SAMESITE=none
COOKIE_SECURE=true
